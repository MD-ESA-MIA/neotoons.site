import React, { useState } from 'react';
import { 
  FileText, 
  Plus, 
  Search, 
  Filter, 
  MoreVertical, 
  ExternalLink, 
  Edit2, 
  Trash2, 
  Eye,
  Globe,
  Lock
} from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { useConfig } from '../../context/ConfigContext';
import { pageService, CustomPage } from '../../services/appServices';
import toast from 'react-hot-toast';

const PageManager: React.FC = () => {
  const { pages } = useConfig();
  const [searchQuery, setSearchQuery] = useState('');

  const filteredPages = pages.filter(page => 
    page.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
    page.slug.toLowerCase().includes(searchQuery.toLowerCase())
  );

  const handleDelete = async (id: string) => {
    if (window.confirm('Are you sure you want to delete this page?')) {
      const success = await pageService.delete(id);
      if (success) toast.success('Page deleted successfully');
    }
  };

  const handleToggleStatus = async (page: CustomPage) => {
    const newStatus = page.status === 'published' ? 'draft' : 'published';
    const success = await pageService.save({ ...page, status: newStatus });
    if (success) toast.success(`Page ${newStatus} successfully`);
  };

  return (
    <div className="space-y-8">
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div className="space-y-1">
          <h1 className="text-3xl font-bold text-white tracking-tight">Page Manager</h1>
          <p className="text-white/40">Create and manage custom pages, legal documents, and landing sections.</p>
        </div>
        <button className="flex items-center gap-2 px-4 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-indigo-500/20">
          <Plus className="w-4 h-4" /> Create New Page
        </button>
      </div>

      <div className="flex flex-col md:flex-row gap-4">
        <div className="relative flex-1">
          <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-white/20" />
          <input 
            type="text"
            placeholder="Search pages by title or slug..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="w-full bg-[#0A0A0B] border border-white/5 rounded-xl py-3 pl-12 pr-4 text-sm text-white focus:outline-none focus:border-indigo-500/50 transition-all"
          />
        </div>
        <button className="flex items-center gap-2 px-4 py-3 bg-[#0A0A0B] border border-white/5 rounded-xl text-xs font-bold text-white/40 hover:text-white transition-all">
          <Filter className="w-4 h-4" /> Filter
        </button>
      </div>

      <div className="bg-[#0A0A0B] border border-white/5 rounded-[32px] overflow-hidden">
        <div className="overflow-x-auto">
          <table className="w-full text-left border-collapse">
            <thead>
              <tr className="border-b border-white/5">
                <th className="px-8 py-6 text-[10px] font-bold text-white/20 uppercase tracking-widest">Page Title</th>
                <th className="px-8 py-6 text-[10px] font-bold text-white/20 uppercase tracking-widest">Slug</th>
                <th className="px-8 py-6 text-[10px] font-bold text-white/20 uppercase tracking-widest">Status</th>
                <th className="px-8 py-6 text-[10px] font-bold text-white/20 uppercase tracking-widest">Last Updated</th>
                <th className="px-8 py-6 text-[10px] font-bold text-white/20 uppercase tracking-widest text-right">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-white/5">
              {filteredPages.map((page) => (
                <tr key={page.id} className="group hover:bg-white/[0.02] transition-colors">
                  <td className="px-8 py-6">
                    <div className="flex items-center gap-4">
                      <div className="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-white/40 group-hover:text-indigo-500 transition-colors">
                        <FileText className="w-5 h-5" />
                      </div>
                      <span className="text-sm font-bold text-white">{page.title}</span>
                    </div>
                  </td>
                  <td className="px-8 py-6">
                    <code className="text-[10px] font-bold text-white/20 bg-white/5 px-2 py-1 rounded">/{page.slug}</code>
                  </td>
                  <td className="px-8 py-6">
                    <button 
                      onClick={() => handleToggleStatus(page)}
                      className={`flex items-center gap-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest transition-all ${
                        page.status === 'published' 
                          ? 'bg-emerald-500/10 text-emerald-500' 
                          : 'bg-white/5 text-white/40'
                      }`}
                    >
                      {page.status === 'published' ? <Globe className="w-3 h-3" /> : <Lock className="w-3 h-3" />}
                      {page.status}
                    </button>
                  </td>
                  <td className="px-8 py-6">
                    <span className="text-xs text-white/40">{new Date(page.updatedAt).toLocaleDateString()}</span>
                  </td>
                  <td className="px-8 py-6 text-right">
                    <div className="flex items-center justify-end gap-2">
                      <button className="p-2 hover:bg-white/5 rounded-xl text-white/40 hover:text-white transition-colors">
                        <Eye className="w-4 h-4" />
                      </button>
                      <button className="p-2 hover:bg-white/5 rounded-xl text-white/40 hover:text-white transition-colors">
                        <Edit2 className="w-4 h-4" />
                      </button>
                      <button 
                        onClick={() => handleDelete(page.id)}
                        className="p-2 hover:bg-white/5 rounded-xl text-white/40 hover:text-rose-500 transition-colors"
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
};

export default PageManager;
