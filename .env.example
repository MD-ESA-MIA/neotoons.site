# ========== NEOTOONS AI - ENVIRONMENT SETUP TEMPLATE ==========
# 🔒 SECURITY NOTICE: Keep .env files secure - never commit or share
# 
# Setup Instructions:
# 1. Copy this file to .env (backend secrets - PRIVATE)
# 2. Copy FRONTEND part below to .env.local (public - can commit)
# 3. Fill in YOUR actual values from service dashboards
# 4. Add .env and .env.local to .gitignore
# 5. Test with: npm run dev

# ============================================================
# STEP 1: Set up .env.local (Frontend - Safe to commit)
# ============================================================
# Copy the following to .env.local in project root:

# Frontend Configuration (SAFE)
VITE_API_URL=http://localhost:5000          # Your backend URL
VITE_CODE_HOSTING=github
VITE_DEPLOY_TARGET=vercel
VITE_DB_PROVIDER=supabase
VITE_AUTH_PROVIDER=clerk
CLIENT_URL=http://localhost:5173            # Your frontend URL

# Supabase (Client keys - intentionally public)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xyzzz...

# Clerk (Public key - safe for frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xyzzz...

# Other settings
VOICE_TTS_DEFAULT_LANG=en


# ============================================================
# STEP 2: Set up .env (Backend - NEVER commit!)
# ============================================================
# Copy the following to .env in project root:
# ⚠️ This file should be in .gitignore

# === SECURITY SECRETS ===
# Generate with: openssl rand -base64 32
JWT_SECRET=[GENERATE-AND-PASTE-32-CHAR-STRING]
ADMIN_SESSION_SECRET=[GENERATE-AND-PASTE-32-CHAR-STRING]

# === CLERK (Authentication) ===
# From: Clerk Dashboard > Developer > API Keys
# Copy the SECRET KEY (not publishable key)
CLERK_SECRET_KEY=[PASTE-YOUR-CLERK-SECRET-KEY]
CLERK_WEBHOOK_SECRET=[PASTE-YOUR-CLERK-WEBHOOK-SECRET]
CLERK_ADMIN_EMAILS=owner@yourdomain.com,admin@yourdomain.com

# === API KEYS (Third-party services) ===

# OpenRouter (AI text generation)
# Sign up: https://openrouter.ai
# Get key: Dashboard > Keys
OPENROUTER_API_KEY=[PASTE-YOUR-OPENROUTER-KEY]

# HuggingFace (Image generation)
# Sign up: https://huggingface.co
# Get token: Settings > Access Tokens
HUGGINGFACE_API_KEY=[PASTE-YOUR-HUGGINGFACE-KEY]

# Resend (Email service)
# Sign up: https://resend.com
# Get key: Dashboard > API Keys
RESEND_API_KEY=[PASTE-YOUR-RESEND-KEY]

# === DATABASE ===
# Supabase URLs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=[PASTE-YOUR-SERVICE-ROLE-KEY]

# Alternative: Direct PostgreSQL (if not using Supabase)
# DATABASE_URL=postgresql://user:password@localhost:5432/neotoons

# === SERVER ===
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,https://your-frontend.vercel.app
CROSS_SITE_COOKIES=true

# === EMAIL ===
APP_EMAIL=your-app-email@neotoons.ai
ADMIN_EMAIL=admin@yourdomain.com

# === OPTIONAL: WEB3FORMS ===
# For contact forms (backend only)
WEB3FORMS_ACCESS_KEY=[OPTIONAL-PASTE-IF-USING]

# === OPTIONAL: MONITORING ===
SENTRY_DSN=https://...sentry.io/...

# === OPTIONAL: STRIPE (Payments) ===
STRIPE_SECRET_KEY=sk_test_...

# === OPTIONAL: REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === OPTIONAL: AWS S3 ===
AWS_ACCESS_KEY_ID=optional
AWS_SECRET_ACCESS_KEY=optional
AWS_REGION=us-east-1
AWS_S3_BUCKET=neotoons-backups


# ============================================================
# OBTAINING VALUES
# ============================================================

# 1. CLERK_SECRET_KEY & CLERK_PUBLISHABLE_KEY
#    Login: https://dashboard.clerk.com
#    Project > Developer > API Keys
#    Copy "Secret Key" (starts with sk_test_)

# 2. SUPABASE_URL & SUPABASE_ANON_KEY
#    Login: https://supabase.com
#    Project > Settings > API
#    Copy "Project URL" and "Anon/Public Key"

# 3. SUPABASE_SERVICE_ROLE_KEY
#    Same location as above, look for "Service Role Key" (hidden by default)

# 4. OPENROUTER_API_KEY
#    Sign up: https://openrouter.ai
#    Dashboard > Keys > Create new key

# 5. HUGGINGFACE_API_KEY
#    Sign up: https://huggingface.co
#    Profile > Settings > Access Tokens

# 6. RESEND_API_KEY
#    Sign up: https://resend.com
#    Dashboard > API Keys

# ============================================================
# SECURITY CHECKLIST
# ============================================================
# ✅ .env is in .gitignore (never committed)
# ✅ .env.local in .gitignore (never committed)
# ✅ .env.example (this file) is safe to commit
# ✅ No secrets in .env.example (use placeholders)
# ✅ All VITE_ variables are non-sensitive
# ✅ All CLERK_SECRET_/OPENROUTER/etc in .env only
# ✅ Backend reads from .env
# ✅ Frontend reads from .env.local
# ✅ Frontend build doesn't include .env

# ============================================================
# TESTING YOUR SETUP
# ============================================================
# 1. Run frontend dev server:
#    npm run dev
#    Should start on http://localhost:5173

# 2. Run backend server (in another terminal):
#    npm run server
#    Should start on http://localhost:5000

# 3. Test API connection:
#    curl http://localhost:5000/api/ai/health

# 4. Verify no secrets in frontend build:
#    npm run build
#    grep -r "sk_test_\|sk-or-v1\|hf_" dist/
#    (should return nothing)

# ============================================================
# DEPLOYMENT NOTES
# ============================================================
# For production deployment:
#
# 1. Create production .env with real secrets
# 2. Use environment variable injection (not .env files)
# 3. Platforms like Vercel/Railway have ways to set ENV vars:
#    - Vercel: Settings > Environment Variables
#    - Railway: Variables section
#    - Docker: --env-file or docker-compose.yml
#
# 4. For GitHub Actions/CI:
#    - Add secrets in repo settings
#    - Reference with ${{ secrets.SECRET_NAME }}
#
# 5. Rotate keys periodically:
#    - Generate new API keys monthly
#    - Update in production
#    - Delete old keys

# ============================================================
# TROUBLESHOOTING
# ============================================================

# Q: "Cannot find module" errors
# A: npm install && npm run dev

# Q: API calls failing with 401
# A: Check .env has correct API keys
# A: Verify jwt.io can decode JWT tokens

# Q: Clerk auth not working
# A: Verify CLERK_PUBLISHABLE_KEY matches in .env.local
# A: Check Clerk dashboard for domain/origin settings

# Q: Email not sending
# A: Test RESEND_API_KEY at https://resend.com
# A: Check ADMIN_EMAIL is valid

# Q: AI generation failing
# A: Test OPENROUTER_API_KEY at https://openrouter.ai/keys
# A: Check account has credits

# Q: Database connection failing
# A: Verify SUPABASE_URL is correct
# A: Check service role key has permissions
# A: Test with: psql $DATABASE_URL
