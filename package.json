  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx src/api/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "vite build && npm run build:api",
    "build:api": "tsc -p tsconfig.backend.json",
    "build:all": "vite build && npm run build:api",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "start": "node dist/api/server.js",
    "start:dev": "tsx src/api/server.ts"
  },
