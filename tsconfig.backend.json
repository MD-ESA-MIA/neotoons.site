{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "noEmit": false,
    "noEmitOnError": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "noPropertyAccessFromIndexSignature": false,
    "strict": false
  },
  "include": ["src/api/**/*", "src/utils/middleware.ts", "src/utils/logger.ts"],
  "exclude": ["node_modules", "dist"],
  "compileOnSave": false
}
